+# =============================================================================
+# Chainglass Harness — Docker Compose (Dev Mode)
+#
+# Runs the full Chainglass dev environment:
+#   - Next.js dev server on :3000 (Turbopack HMR)
+#   - Terminal WebSocket sidecar on :4500
+#   - Source code bind-mounted from host for live editing
+#   - Named volume for node_modules (Linux-compiled binaries)
+#
+# Usage:
+#   cd harness && docker compose up
+#   cd harness && just dev
+# =============================================================================
+
+services:
+  chainglass-dev:
+    build:
+      context: .
+      dockerfile: Dockerfile
+      target: dev
+    container_name: chainglass-dev
+    ports:
+      - "3000:3000"     # Next.js dev server
+      - "4500:4500"     # Terminal WebSocket sidecar
+      - "9222:9222"     # CDP (Playwright, Phase 2)
+    volumes:
+      # Bind mount entire monorepo for HMR (OrbStack: 2-way sync)
+      - ..:/app
+      # Named volume shadows host node_modules — Linux binaries, not macOS
+      - chainglass_node_modules:/app/node_modules
+      # Named volume for .next build cache (avoid cross-OS issues)
+      - chainglass_dot_next:/app/apps/web/.next
+    environment:
+      - NODE_ENV=development
+      - DISABLE_AUTH=true
+      - PORT=3000
+      - TERMINAL_WS_HOST=0.0.0.0
+      - TERMINAL_ALLOWED_BASE=/app
+      - AUTH_SECRET=harness-dev-secret-not-for-production
+    # Shared memory for headless Chromium (Phase 2)
+    shm_size: '1gb'
+    healthcheck:
+      test: ["CMD", "curl", "-sf", "http://localhost:3000/"]
+      interval: 10s
+      timeout: 5s
+      retries: 30
+      start_period: 120s
+    restart: unless-stopped
+
+volumes:
+  chainglass_node_modules:
+    name: chainglass_node_modules
+  chainglass_dot_next:
+    name: chainglass_dot_next
