+  async saveOutputFile(
+    ctx: WorkspaceContext,
+    graphSlug: string,
+    nodeId: string,
+    outputName: string,
+    sourcePath: string
+  ) {
+    this.track('saveOutputFile', [ctx, graphSlug, nodeId, outputName, sourcePath]);
