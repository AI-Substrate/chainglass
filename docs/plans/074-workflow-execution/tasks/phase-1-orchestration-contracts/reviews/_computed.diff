+ظ¤é 13. // drive() runs in background ظ¤ NOT awaited here            ظ¤é
+ظ¤é 14. handle.drivePromise.then(result => {                        ظ¤é
+ظ¤é       handle.status = result.exitReason === 'complete'          ظ¤é
