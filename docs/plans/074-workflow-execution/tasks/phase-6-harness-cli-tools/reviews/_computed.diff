+      })
+    );
+    process.exit(1);
+  }
+
+  const service = getWorkUnitService();
+  const result = await service.delete(ctx, slug);
+  console.log(adapter.format('unit.delete', result));
+
+  if (result.errors.length > 0) {
+    process.exit(1);
+  }
+}
