+  const buffer = Buffer.from(arrayBuffer);
+
+  return uploadFileService({
+    worktreePath,
+    fileName: file.name,
+    mimeType: file.type,
+    content: buffer,
+    fileSystem,
+    pathResolver,
+  });
+}
