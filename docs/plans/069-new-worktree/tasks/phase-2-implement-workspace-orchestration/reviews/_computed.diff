+    this._remoteBranches = ['origin/main'];
+    this._planFolders = [];
+  }
+
+  // ==================== IGitWorktreeManager Implementation ====================
+
+  async checkMainStatus(mainRepoPath: string): Promise<MainStatusResult> {
