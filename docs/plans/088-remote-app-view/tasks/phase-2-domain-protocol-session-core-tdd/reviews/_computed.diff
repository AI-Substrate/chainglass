+{
+  "$comment": "Canonical wire-protocol CONTROL-message fixtures (Workshop 003). Cross-language source of truth: the TS suite (protocol-messages.test.ts) and the Swift daemon (Plan 088 Task 4.2) both round-trip these exact objects. Binary video frames are covered separately by frame-header.json (T004) + fixtures/video/ (T005). Any protocol change regenerates this file AND frame-header.json, then re-runs T003 + T004 + Task 4.2.",
+  "version": 1,
+  "client": [
+    { "t": "hello", "v": 1, "session": "ses_abc123def456" },
+    {
+      "t": "input",
+      "events": [
+        { "k": "mousemove", "x": 0.5, "y": 0.25 },
+        { "k": "mousedown", "x": 0.5, "y": 0.25, "button": 0 },
+        { "k": "mouseup", "x": 0.5, "y": 0.25, "button": 2 },
+        { "k": "wheel", "x": 0.5, "y": 0.25, "dx": 0, "dy": -120 },
+        { "k": "keydown", "code": "KeyW", "modifiers": { "shift": false, "ctrl": false, "alt": false, "meta": true } },
+        { "k": "keyup", "code": "KeyW", "modifiers": { "shift": false, "ctrl": false, "alt": false, "meta": false } },
+        { "k": "text", "text": "café" }
+      ]
+    },
+    { "t": "request-keyframe" },
