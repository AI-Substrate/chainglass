+  it('ignores Jordans-MacBook-Pro.local', () => {
+    expect(shouldIgnorePaneTitle('Jordans-MacBook-Pro.local')).toBe(true);
+  });
+
+  it('ignores empty string', () => {
+    expect(shouldIgnorePaneTitle('')).toBe(true);
+  });
