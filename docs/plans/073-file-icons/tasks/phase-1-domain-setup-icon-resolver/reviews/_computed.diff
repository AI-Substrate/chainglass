+import type { IconThemeManifest } from '../types';
+
+// In Phase 1, this is a minimal hardcoded manifest for compilation.
+// Phase 2 replaces this with the real generated manifest from material-icon-theme.
+let cachedManifest: IconThemeManifest | null = null;
+
+/**
+ * Load an icon theme manifest by theme ID.
+ * Phase 1: returns a minimal manifest for testing.
+ * Phase 2: loads the generated manifest from public/icons/{themeId}/manifest.json.
+ */
+export async function loadManifest(
+  _themeId: string,
+): Promise<IconThemeManifest> {
+  if (cachedManifest) return cachedManifest;
+
+  // Phase 2 will replace this with:
+  // const response = await fetch(`/icons/${themeId}/manifest.json`);
+  // const data = await response.json();
+  // cachedManifest = normalizeManifest(data);
+
+  // For now, return empty manifest that satisfies the type
+  cachedManifest = {
+    fileNames: {},
+    fileExtensions: {},
+    languageIds: {},
+    folderNames: {},
+    folderNamesExpanded: {},
+    iconDefinitions: {},
+    light: {},
+    file: 'file',
+    folder: 'folder',
+    folderExpanded: 'folder-open',
+  };
+
+  return cachedManifest;
+}
+
+/** Clear cached manifest (for testing or theme switching) */
+export function clearManifestCache(): void {
+  cachedManifest = null;
+}
