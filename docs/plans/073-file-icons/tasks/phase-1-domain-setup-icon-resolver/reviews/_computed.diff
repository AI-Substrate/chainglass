+import type { IconThemeManifest, IconResolution } from '../types';
+
+// Extension → VSCode languageId mapping for extensions not in fileExtensions
+const EXTENSION_TO_LANGUAGE_ID: Record<string, string> = {
+  ts: 'typescript',
+  mts: 'typescript',
+  cts: 'typescript',
+  js: 'javascript',
+  mjs: 'javascript',
+  cjs: 'javascript',
+  jsx: 'javascriptreact',
+  tsx: 'typescriptreact',
+};
+
+/**
+ * Resolve a filename to an icon using the VSCode icon theme manifest format.
+ * Priority: fileNames → fileExtensions → languageIds → default.
+ * When theme is 'light', checks manifest.light.* first for each source.
+ */
+export function resolveFileIcon(
+  filename: string,
+  manifest: IconThemeManifest,
+  theme?: 'light' | 'dark',
+): IconResolution {
+  const lowerFilename = filename.toLowerCase();
+
+  // 1. Check fileNames (exact filename match)
+  if (theme === 'light' && manifest.light.fileNames) {
+    const lightMatch = manifest.light.fileNames[lowerFilename];
+    if (lightMatch) {
+      return { iconName: lightMatch, source: 'fileName' };
+    }
+  }
+  const fileNameMatch = manifest.fileNames[lowerFilename];
+  if (fileNameMatch) {
+    return { iconName: fileNameMatch, source: 'fileName' };
+  }
+
+  // 2. Check fileExtensions
+  const ext = extractExtension(lowerFilename);
+  if (ext) {
+    if (theme === 'light' && manifest.light.fileExtensions) {
+      const lightMatch = manifest.light.fileExtensions[ext];
+      if (lightMatch) {
+        return { iconName: lightMatch, source: 'fileExtension' };
+      }
+    }
+    const extMatch = manifest.fileExtensions[ext];
+    if (extMatch) {
+      return { iconName: extMatch, source: 'fileExtension' };
+    }
+  }
+
+  // 3. Check languageIds (critical for .ts which is NOT in fileExtensions)
+  const langId = ext ? EXTENSION_TO_LANGUAGE_ID[ext] : undefined;
+  if (langId) {
+    if (theme === 'light' && manifest.light.languageIds) {
+      const lightMatch = manifest.light.languageIds[langId];
+      if (lightMatch) {
+        return { iconName: lightMatch, source: 'languageId' };
+      }
+    }
+    const langMatch = manifest.languageIds[langId];
+    if (langMatch) {
+      return { iconName: langMatch, source: 'languageId' };
+    }
+  }
+
+  // 4. Default
+  return { iconName: manifest.file, source: 'default' };
+}
+
+/**
+ * Resolve a folder name to a folder icon.
+ * Checks folderNames/folderNamesExpanded → default folder/folder-open.
+ */
+export function resolveFolderIcon(
+  folderName: string,
+  expanded: boolean,
+  manifest: IconThemeManifest,
+  theme?: 'light' | 'dark',
+): IconResolution {
+  const lowerName = folderName.toLowerCase();
+  const source = expanded ? manifest.folderNamesExpanded : manifest.folderNames;
+
+  if (theme === 'light') {
+    const lightSource = expanded
+      ? manifest.light.folderNamesExpanded
+      : manifest.light.folderNames;
+    if (lightSource) {
+      const lightMatch = lightSource[lowerName];
+      if (lightMatch) {
+        return { iconName: lightMatch, source: 'fileName' };
+      }
+    }
+  }
+
+  const match = source[lowerName];
+  if (match) {
+    return { iconName: match, source: 'fileName' };
+  }
+
+  // Default
+  const defaultIcon = expanded ? manifest.folderExpanded : manifest.folder;
+  return { iconName: defaultIcon, source: 'default' };
+}
+
+function extractExtension(filename: string): string | undefined {
+  const lastDot = filename.lastIndexOf('.');
+  if (lastDot <= 0 || lastDot === filename.length - 1) return undefined;
+  return filename.slice(lastDot + 1);
+}
