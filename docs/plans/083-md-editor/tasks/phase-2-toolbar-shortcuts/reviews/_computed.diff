    // firing unreliable from Playwright on touch viewports. Phase 2's T008
    // targets desktop + tablet; mobile toolbar + link-popover behavior is
    // owned by Phase 6.4 (plan § Phase 6 Risks). The desktop/tablet runs
    // still cover AC-04 and AC-05.
    test.skip(
      testInfo.project.name === 'mobile',
      'Mobile toolbar verification is Phase 6.4 scope',
    );
    /*
    Test Doc:
    - Why: This is the end-to-end proof that the Phase 2 toolbar composes with
      Phase 1's editor on the real Next 16 + React 19 runtime — the harness
      is the authoritative check for click-driven formatting (AC-04) and the
      StarterKit keyboard shortcut matrix (AC-05).
    - Contract: 16 toolbar buttons rendered with `role="toolbar"`; clicking
      Bold and H2 mutates the editor DOM as expected; Mod-Alt-C keybinding
      inserts a code block.
    - Usage Notes: Requires the dev-only route and the harness Docker container
      running. Cross-platform `Mod-` detection ensures the same spec runs on
      Mac (Meta) and Linux CI (Control).
    - Quality Contribution: Locks in the Phase 1 → Phase 2 composition (editor
      + toolbar via `onEditorReady`), the StarterKit keybinding contract, and
      Phase 6's AC-16b placeholder-visible promise.
    */
    const hydrationWarnings: string[] = [];
    cdpPage.on('console', (msg) => {
      const type = msg.type();
      if (type !== 'warning' && type !== 'error') return;
      if (HYDRATION_RX.test(msg.text())) hydrationWarnings.push(msg.text());
    });

    const response = await cdpPage.goto(`${baseURL}${SMOKE_PATH}`, {
      waitUntil: 'domcontentloaded',
    });
    expect(response?.status()).toBe(200);

    // Phase 1 assertions — preserved verbatim.
    await cdpPage.waitForSelector('[data-testid="md-wysiwyg-root"]', { timeout: 15_000 });
    const editorRoot = cdpPage.locator('[data-testid="md-wysiwyg-root"]');
    const h1Text = await editorRoot.locator('h1').first().textContent();
    expect(h1Text).toContain('Hello');
    const imgSrc = await editorRoot.locator('img').first().getAttribute('src');
    expect(imgSrc).not.toBeNull();
    expect(imgSrc).toMatch(/\/api\/workspaces\/test\/files\/raw\?worktree=test&file=/);

    // Phase 2 assertions — toolbar shape.
    const toolbar = cdpPage.locator('[data-testid="wysiwyg-toolbar"]');
    await toolbar.waitFor({ timeout: 5_000 });
    await expect(toolbar).toHaveAttribute('role', 'toolbar');
    const buttons = toolbar.locator('[data-testid^="toolbar-"]');
    await expect(buttons).toHaveCount(16);

    // Phase 2 assertions — Bold click.
    // Focus the editor and select the "Hello" text so Bold has something to toggle.
    await editorRoot.locator('h1').first().click();
    await cdpPage.keyboard.press(`${MOD_KEY}+a`);
    await cdpPage.locator('[data-testid="toolbar-bold"]').click();
    // Select-all across the sample markdown wraps multiple text runs, so
    // expect at least one <strong>.
    await expect(editorRoot.locator('strong').first()).toBeVisible({ timeout: 5_000 });

    // Phase 2 assertions — H2 click.
    // Move caret to the "Some text." paragraph and toggle H2.
    await editorRoot.locator('p', { hasText: 'Some text.' }).click();
    await cdpPage.locator('[data-testid="toolbar-h2"]').click();
    await expect(editorRoot.locator('h2').first()).toBeVisible({ timeout: 5_000 });

    // Phase 2 assertions — Mod-Alt-C keybinding (StarterKit default).
    // Place caret in a fresh paragraph via End key so we don't disturb earlier state.
    await editorRoot.click();
    await cdpPage.keyboard.press(`${MOD_KEY}+End`);
    await cdpPage.keyboard.press(`${MOD_KEY}+Alt+c`);
    // Expect a <pre><code> to appear somewhere in the editor root.
    await expect(editorRoot.locator('pre code').first()).toBeVisible({ timeout: 5_000 });

    // Settle any residual hydration work before asserting the console log.
    await cdpPage.waitForLoadState('networkidle');

    // Screenshot evidence.
    if (!existsSync(RESULTS_DIR)) mkdirSync(RESULTS_DIR, { recursive: true });
    const screenshot = join(RESULTS_DIR, `toolbar-${testInfo.project.name}.png`);
    await cdpPage.screenshot({ path: screenshot, fullPage: false });
    expect(existsSync(screenshot)).toBe(true);

    expect(hydrationWarnings, hydrationWarnings.join('\n')).toEqual([]);
  });
});

