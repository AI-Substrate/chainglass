+        </div>
+      )}
+
+      <p className="mb-6 font-mono text-sm text-neutral-400">System access required</p>
+
+      <SignInButton />
+    </div>
+  );
+}
diff --git a/apps/web/proxy.ts b/apps/web/proxy.ts
new file mode 100644
index 0000000..c39d060
--- /dev/null
+++ b/apps/web/proxy.ts
@@ -0,0 +1,22 @@
+import { auth } from '@/auth';
+import { NextResponse } from 'next/server';
+
+export const runtime = 'nodejs';
+
+export default auth((req) => {
+  if (!req.auth) {
+    const isApiRoute = req.nextUrl.pathname.startsWith('/api/');
+    if (isApiRoute) {
+      return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
+    }
+    const loginUrl = new URL('/login', req.nextUrl.origin);
+    return NextResponse.redirect(loginUrl);
+  }
+  return NextResponse.next();
+});
+
+export const config = {
+  matcher: [
+    '/((?!login|api/health|api/auth|_next/static|_next/image|favicon\\.ico).*)',
+  ],
+};
