+      {error === 'AccessDenied' && (
+        <div role="alert" className="mb-6 rounded-md bg-red-950 px-4 py-3 font-mono text-sm text-red-400">
+          Access denied: your GitHub account is not authorized
+        </div>
+      )}
+
+      {error && error !== 'AccessDenied' && (
+        <div role="alert" className="mb-6 rounded-md bg-red-950 px-4 py-3 font-mono text-sm text-red-400">
