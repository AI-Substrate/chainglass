+ *
+ * Server-only exports (lib/) must be imported directly, not via barrel.
+ *
+ * Plan 071: PR View & File Notes — Phase 4 (types), Phase 5 (hooks/components/SDK)
+ */
+
+export type {
+  BranchChangedFile,
+  ComparisonMode,
+  DiffFileStats,
+  DiffFileStatus,
