+```typescript
+// debug-log.ts
+const DEBUG_LOG: DebugEntry[] = [];
+
+export function debugLog(component: string, event: string, data: Record<string, unknown>) {
+  DEBUG_LOG.push({
+    ts: Date.now(),
+    component,
+    event,
+    data,
+  });
+}
+
+export function dumpDebugLog(path: string) {
+  writeFileSync(path, JSON.stringify(DEBUG_LOG, null, 2));
+}
