-
-        if (!response.ok || (data.errors && data.errors.length > 0)) {
-          setError(data.errors?.[0]?.message ?? 'Failed to load units');
-          setUnits([]);
-        } else {
-          setUnits(data.units ?? []);
-        }
-      } catch (err) {
-        setError('Failed to load units');
-        setUnits([]);
-      } finally {
-        setLoading(false);
-      }
