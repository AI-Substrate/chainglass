-            isAccepted: true,
-            isBlocked: false,
-          };
-        })
-      );
-
-      onPhaseChange?.(phaseName, 'accepted');
-    },
-    [onPhaseChange, updatePhaseStatus]
-  );
-
-  return {
-    phases,
-    isRunning,
-    start,
-    pause,
-    reset,
-    answerQuestion,
-  };
-}
