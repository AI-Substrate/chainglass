-      try {
-        const url = new URL(`/api/workspaces/${workspaceSlug}/units`, window.location.origin);
-        if (worktreePath) {
-          url.searchParams.set('worktree', worktreePath);
-        }
-
-        const response = await fetch(url.toString());
