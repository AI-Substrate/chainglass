+
+  it('returns 403 for proxied requests', () => {
+    const req = makeRequest({
+      ip: '127.0.0.1',
+      headers: { 'x-forwarded-for': '10.0.0.1' },
+    });
+    const result = localhostGuard(req);
+    expect(result).not.toBeNull();
+    expect(result?.status).toBe(403);
+  });
+});
