+/**
+ * Mux Route Contract Tests — Plan 072 Phase 1
+ *
+ * Tests for the /api/events/mux multiplexed SSE endpoint.
+ * Focuses on the SSEManager contract: channel validation, multi-channel
+ * registration, and atomic cleanup. Streaming and auth are verified
+ * via manual testing (DYK: first-of-kind route handler test).
+ *
+ * Per DYK-04: Tests SSEManager interaction, not actual ReadableStream
+ * streaming — that's an integration concern for manual DevTools verification.
+ */
+import { beforeEach, describe, expect, it } from 'vitest';
+import { FakeController } from '../../../fakes/fake-controller';
+import { SSEManager } from '../../../../apps/web/src/lib/sse-manager';
+
+/** Channel validation regex — mirrors the one in mux/route.ts */
+const CHANNEL_PATTERN = /^[a-zA-Z0-9_-]+$/;
+const MAX_CHANNELS = 20;
+
+/**
+ * Parses and validates a channels query parameter.
+ * Extracted here to test the exact logic the route uses.
+ */
+function parseChannels(channelsParam: string | null): {
+  ok: boolean;
+  channels: string[];
+  error?: string;
+} {
+  if (!channelsParam) {
+    return { ok: false, channels: [], error: 'Missing channels query parameter' };
+  }
+
+  const channels = [...new Set(channelsParam.split(',').filter(Boolean))];
+
+  if (channels.length === 0) {
+    return { ok: false, channels: [], error: 'No valid channels provided' };
+  }
+
+  if (channels.length > MAX_CHANNELS) {
+    return {
+      ok: false,
+      channels: [],
+      error: `Too many channels (max ${MAX_CHANNELS}, got ${channels.length})`,
+    };
+  }
+
+  for (const ch of channels) {
+    if (!CHANNEL_PATTERN.test(ch)) {
+      return { ok: false, channels: [], error: `Invalid channel name: ${ch}` };
+    }
+  }
+
+  return { ok: true, channels };
+}
+
+describe('/api/events/mux route contract', () => {
+  describe('channel validation', () => {
+    it('should reject missing channels parameter', () => {
+      /*
+      Test Doc:
+      - Why: Route must require channels param — connecting without channels is meaningless
+      - Contract: null channels param → error with descriptive message
+      - Usage Notes: Tests the validation path, not the HTTP response code
+      - Quality Contribution: Input validation boundary
+      - Worked Example: parseChannels(null) → {ok: false, error: 'Missing...'}
+      */
+      const result = parseChannels(null);
+      expect(result.ok).toBe(false);
+      expect(result.error).toContain('Missing');
+    });
+
+    it('should reject empty channels string', () => {
+      /*
+      Test Doc:
+      - Why: Empty string after split produces no valid channels
+      - Contract: '' → error
+      - Usage Notes: Edge case — user sends ?channels= with no value
+      - Quality Contribution: Robustness
+      - Worked Example: parseChannels('') → {ok: false}
+      */
+      const result = parseChannels('');
+      expect(result.ok).toBe(false);
+    });
+
+    it('should reject invalid channel names', () => {
+      /*
+      Test Doc:
+      - Why: Channel names must be safe for SSE protocol (no injection)
+      - Contract: Names with special chars → error identifying the bad name
+      - Usage Notes: Tests regex boundary: spaces, newlines, colons rejected
+      - Quality Contribution: Security boundary — prevents SSE injection via channel name
+      - Worked Example: parseChannels('good,bad name') → error mentioning 'bad name'
+      */
+      const result = parseChannels('good,bad name');
+      expect(result.ok).toBe(false);
+      expect(result.error).toContain('bad name');
+
+      const result2 = parseChannels('has:colon');
+      expect(result2.ok).toBe(false);
+
+      const result3 = parseChannels('new\nline');
+      expect(result3.ok).toBe(false);
+    });
+
+    it('should reject more than 20 channels', () => {
+      /*
+      Test Doc:
+      - Why: Prevent abuse — one connection subscribing to hundreds of channels
+      - Contract: >MAX_CHANNELS → error with count
+      - Usage Notes: Generate 21 channel names
+      - Quality Contribution: DoS prevention
+      - Worked Example: 21 channels → error mentioning 'max 20'
+      */
+      const channels = Array.from({ length: 21 }, (_, i) => `ch-${i}`).join(',');
+      const result = parseChannels(channels);
+      expect(result.ok).toBe(false);
+      expect(result.error).toContain('max 20');
+    });
+
+    it('should deduplicate channels', () => {
+      /*
+      Test Doc:
+      - Why: Duplicate channels waste Set entries and confuse cleanup
+      - Contract: 'a,b,a,c,b' → unique ['a', 'b', 'c']
+      - Usage Notes: Dedup happens before count check and validation
+      - Quality Contribution: Correctness — prevents double-registration
+      - Worked Example: parseChannels('a,a,b') → {ok: true, channels: ['a','b']}
+      */
+      const result = parseChannels('file-changes,event-popper,file-changes');
+      expect(result.ok).toBe(true);
+      expect(result.channels).toHaveLength(2);
+      expect(result.channels).toContain('file-changes');
+      expect(result.channels).toContain('event-popper');
+    });
+
+    it('should accept valid channel names', () => {
