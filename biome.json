{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  },
  "files": {
    "ignore": [
      "node_modules",
      "dist",
      ".next",
      ".turbo",
      "pnpm-lock.yaml",
      "*.md",
      "scripts",
      ".vsc-bridge",
      ".chainglass",
      "apps/web/src/components/ui",
      "apps/web/src/hooks/use-mobile.ts",
      "**/next-env.d.ts",
      "coverage",
      "test/coverage",
      "harness",
      "scratch",
      ".pnpm-store",
      "packages/*/src/**/*.d.ts",
      "packages/*/src/**/*.d.ts.map",
      "packages/*/src/**/*.js",
      "packages/*/src/**/*.js.map",
      "apps/web/public/icons/**"
    ]
  }
}
