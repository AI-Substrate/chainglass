{
  "name": "@chainglass/workflow",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./interfaces": {
      "import": "./dist/interfaces/index.js",
      "types": "./dist/interfaces/index.d.ts"
    },
    "./fakes": {
      "import": "./dist/fakes/index.js",
      "types": "./dist/fakes/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "types": "./dist/adapters/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./schemas/*": "./schemas/*"
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run"
  },
  "dependencies": {
    "@chainglass/shared": "workspace:*",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chokidar": "^5.0.0",
    "slugify": "^1.6.6",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
