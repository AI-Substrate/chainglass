{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Code Review Companion Farewell Envelope",
  "type": "object",
  "additionalProperties": true,
  "required": ["session", "findings", "summary", "retrospective"],
  "properties": {
    "session": {
      "type": "object",
      "additionalProperties": true,
      "required": ["startedAt", "endedAt", "exitReason", "messageCounts"],
      "properties": {
        "startedAt": { "type": "string" },
        "endedAt": { "type": "string" },
        "exitReason": {
          "type": "string",
          "enum": ["stop_requested", "idle_budget", "timeout", "error"]
        },
        "messageCounts": {
          "type": "object",
          "additionalProperties": true,
          "required": ["tasksReceived", "findingsSent", "questionsAsked"],
          "properties": {
            "tasksReceived": { "type": "integer", "minimum": 0 },
            "findingsSent": { "type": "integer", "minimum": 0 },
            "questionsAsked": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "severity", "file", "issue", "recommendation"],
        "properties": {
          "id": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"]
          },
          "file": { "type": "string" },
          "category": { "type": "string" },
          "issue": { "type": "string" },
          "recommendation": { "type": "string" },
          "ackOf": {
            "type": "string",
            "description": "Optional inbox message id (outside task) this finding answers."
          }
        }
      }
    },
    "summary": { "type": "string", "minLength": 50 },
    "retrospective": {
      "type": "object",
      "additionalProperties": true,
      "required": ["magicWand", "magicWandTarget"],
      "properties": {
        "magicWand": { "type": "string", "minLength": 10 },
        "magicWandTarget": {
          "type": "string",
          "enum": ["project", "minih", "coordination"]
        },
        "notes": { "type": "string" }
      }
    }
  }
}
