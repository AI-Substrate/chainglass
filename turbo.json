{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "!.next/**/*.map"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["CHAINGLASS_WATCH_POLLING", "CHAINGLASS_WATCH_POLL_INTERVAL"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": true
    }
  }
}
