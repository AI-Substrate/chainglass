# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=your_github_client_id
AUTH_GITHUB_SECRET=your_github_client_secret

# Session encryption key
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_random_secret_here

# Set to 'true' to bypass authentication (for testing/debugging/LAN access)
# DISABLE_AUTH=true

# Terminal sidecar: base directory for allowed CWD paths
# All worktree paths must be under this directory
# TERMINAL_ALLOWED_BASE=/Users/yourname

# Terminal sidecar: dev tunnels / Codespaces support.
# Each tunnel port lives on its own subdomain, so the client's default
# (page-port + 1500) WS URL can't reach the sidecar. Point it at the 4500 URL,
# and allow the page origin on the WS sidecar. The override only engages on
# remote/proxy hosts, so it is safe to leave set permanently (localhost/LAN
# ignore it). See docs/how/dev/terminal-setup.md.
# NEXT_PUBLIC_TERMINAL_WS_URL=wss://<id>-4500.<region>.devtunnels.ms/terminal
# TERMINAL_WS_ALLOWED_ORIGINS=https://<id>-3000.<region>.devtunnels.ms

# File-watch polling fallback (edge case — WSL with the workspace on a Windows mount)
# Native fs.watch (inotify) silently delivers NO events when the workspace lives on a
# Windows drive mounted into WSL2 (e.g. /mnt/c/..., drvfs/9P), so file changes go undetected.
# Set this to 'true' to force a recursive polling watcher instead. Leave unset everywhere else
# (native watching is cheaper and instant). Polling walks the tree on an interval, so it costs
# more CPU/IO — reuse the default interval unless you need faster detection.
# CHAINGLASS_WATCH_POLLING=true
#
# Poll interval in milliseconds (only used when polling is active). Default: 1000.
# Invalid or unset values fall back to 1000ms.
# CHAINGLASS_WATCH_POLL_INTERVAL=1000

# ── Remote View (Plan 088) — HTTPS / LAN streaming (T003) ───────────────────────
# The streamd daemon's WebSocket binds 127.0.0.1 (loopback) and gates the upgrade on the
# request Origin. CG_REMOTE_VIEW__ALLOWED_ORIGINS is a comma-separated allowlist; the web
# server spawns streamd inheriting its process.env, so setting it here propagates to the daemon.
#   - On http://localhost the browser connects DIRECTLY to ws://127.0.0.1:<daemonPort> with
#     Origin http://localhost:<port> — include that origin.
#   - For HTTPS/LAN, the browser connects SAME-ORIGIN to wss://<host>/remote-view-ws, which a
#     reverse proxy (Caddy) bridges to the loopback daemon; the daemon then sees Origin
#     https://<host> — include that origin too. (Caddy + Porkbun DNS-01 recipe: docs/how/remote-view.md.)
# CG_REMOTE_VIEW__ALLOWED_ORIGINS=http://localhost:3000,https://remote.example.com
#
# NextAuth/Auth.js behind the reverse proxy: trust the proxy's forwarded host and pin the public URL,
# or the session/callback URLs resolve to the internal origin and auth breaks over HTTPS.
# AUTH_TRUST_HOST=true
# AUTH_URL=https://remote.example.com
#
# Optional: pin the daemon's loopback port (otherwise webPort + offset). Used by ensureDaemon.
# CG_REMOTE_VIEW__DAEMON_PORT=4501
