# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=your_github_client_id
AUTH_GITHUB_SECRET=your_github_client_secret

# Session encryption key
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_random_secret_here

# Set to 'true' to bypass authentication (for testing/debugging/LAN access)
# DISABLE_AUTH=true

# Terminal sidecar: base directory for allowed CWD paths
# All worktree paths must be under this directory
# TERMINAL_ALLOWED_BASE=/Users/yourname
