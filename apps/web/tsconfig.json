{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "incremental": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@chainglass/shared": ["../../packages/shared/dist"],
      "@chainglass/shared/*": ["../../packages/shared/dist/*"],
      "@chainglass/positional-graph": ["../../packages/positional-graph/dist"],
      "@chainglass/positional-graph/*": ["../../packages/positional-graph/dist/*"],
      "@chainglass/web": ["./src"],
      "@chainglass/web/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "app/**/*", "test/**/*", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "dist", ".next"]
}
