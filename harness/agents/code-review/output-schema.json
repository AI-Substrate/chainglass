{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Code Review Report",
  "description": "Structured output from the harness code-review agent. Contains findings, verdict, domain compliance, and retrospective.",
  "type": "object",
  "required": ["filePath", "filesReviewed", "findings", "domainCompliance", "verdict", "summary", "retrospective"],
  "additionalProperties": true,
  "properties": {
    "filePath": {
      "type": "string",
      "description": "The input file_path that was reviewed."
    },
    "filesReviewed": {
      "type": "array",
      "description": "List of files that were reviewed.",
      "items": {
        "type": "object",
        "required": ["path", "action"],
        "additionalProperties": true,
        "properties": {
          "path": {
            "type": "string",
            "description": "Absolute file path."
          },
          "action": {
            "type": "string",
            "enum": ["created", "modified", "deleted"],
            "description": "What happened to this file."
          },
          "domain": {
            "type": "string",
            "description": "Domain this file belongs to (if applicable)."
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "description": "Code review findings ordered by severity.",
      "items": {
        "type": "object",
        "required": ["id", "severity", "category", "file", "issue", "suggestion"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "description": "Finding ID (e.g., F001, F002)."
          },
          "severity": {
            "type": "string",
            "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"],
            "description": "Finding severity."
          },
          "category": {
            "type": "string",
            "enum": ["correctness", "security", "error-handling", "performance", "pattern", "domain", "reinvention", "testing"],
            "description": "Finding category."
          },
          "file": {
            "type": "string",
            "description": "File path and optional line range (e.g., 'src/foo.ts:10-20')."
          },
          "issue": {
            "type": "string",
            "description": "What the problem is."
          },
          "suggestion": {
            "type": "string",
            "description": "Concrete fix recommendation."
          }
        }
      }
    },
    "domainCompliance": {
      "type": "object",
      "description": "Domain compliance check results.",
      "additionalProperties": true,
      "properties": {
        "applicable": {
          "type": "boolean",
          "description": "Whether domain system exists in this repo."
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["check", "status"],
            "additionalProperties": true,
            "properties": {
              "check": {
                "type": "string",
                "description": "Name of the compliance check."
              },
              "status": {
                "type": "string",
                "enum": ["pass", "fail", "n/a"],
                "description": "Check result."
              },
              "details": {
                "type": "string",
                "description": "Additional details if failed."
              }
            }
          }
        }
      }
    },
    "reinventionCheck": {
      "type": "array",
      "description": "Anti-reinvention check results for new components.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "newComponent": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "existingMatch": {
            "type": "string"
          },
          "recommendation": {
            "type": "string",
            "enum": ["reuse", "extend", "proceed"]
          }
        }
      }
    },
    "harnessValidation": {
      "type": "object",
      "description": "Live harness validation results (if performed).",
      "additionalProperties": true,
      "properties": {
        "performed": {
          "type": "boolean"
        },
        "harnessStatus": {
          "type": "string"
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "description": { "type": "string" },
              "result": { "type": "string", "enum": ["pass", "fail", "skip"] },
              "evidence": { "type": "string" }
            }
          }
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["APPROVE", "APPROVE_WITH_NOTES", "REQUEST_CHANGES"],
      "description": "Overall review verdict."
    },
    "summary": {
      "type": "string",
      "description": "3-5 sentence summary of the review: overall quality, domain compliance, reinvention check, testing evidence."
    },
    "retrospective": {
      "type": "object",
      "description": "Honest feedback on the harness experience. This is the most valuable part of the report.",
      "required": ["workedWell", "confusing", "magicWand"],
      "additionalProperties": true,
      "properties": {
        "workedWell": {
          "type": "string",
          "description": "What CLI commands were intuitive and worked well? What was pleasant about the review workflow?"
        },
        "confusing": {
          "type": "string",
          "description": "What was confusing, unclear, or required trial-and-error?"
        },
        "magicWand": {
          "type": "string",
          "description": "If you could add or change one thing about the harness to make code review easier, what would it be? Be concrete."
        },
        "cliDiscoverability": {
          "type": "string",
          "description": "How discoverable were the CLI commands?"
        },
        "improvementSuggestions": {
          "type": "array",
          "description": "1-3 specific, actionable improvements.",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
