# Harness Development Commands

# Default - show help
default:
    @just --list

# Build Docker image
build:
    docker compose -f docker-compose.yml build

# Install standalone harness dependencies
install:
    pnpm install --ignore-workspace

# Start dev container (detached), wait for health
dev:
    docker compose -f docker-compose.yml up -d
    @echo "Waiting for health..."
    @for i in $(seq 1 60); do \
        if curl -sf http://localhost:3000 > /dev/null 2>&1; then \
            echo "✓ App healthy on :3000"; \
            break; \
        fi; \
        sleep 2; \
    done

# Stop and remove container
stop:
    docker compose -f docker-compose.yml down

# Health check
health:
    @APP_CODE=$(curl -sf -o /dev/null -w '%{http_code}' http://127.0.0.1:3000 || echo DOWN); \
    MCP_CODE=$(curl -s -o /dev/null -w '%{http_code}' http://127.0.0.1:3000/_next/mcp || echo DOWN); \
    TERMINAL_STATUS=$(python3 -c "import socket; s=socket.create_connection(('127.0.0.1',4500),2); s.close(); print('up')" 2>/dev/null || echo down); \
    CDP_BROWSER=$(curl -sf http://127.0.0.1:9222/json/version | tr -d '\n' | sed -E 's/.*\"Browser\"[[:space:]]*:[[:space:]]*\"([^\"]+)\".*/\1/' || echo down); \
    APP_CODE="$APP_CODE" MCP_CODE="$MCP_CODE" TERMINAL_STATUS="$TERMINAL_STATUS" CDP_BROWSER="$CDP_BROWSER" python3 -c "import json, os; app=os.environ['APP_CODE']; mcp=os.environ['MCP_CODE']; terminal=os.environ['TERMINAL_STATUS']; cdp=os.environ['CDP_BROWSER']; print(json.dumps({'status': 'ok' if app == '200' and terminal == 'up' and cdp != 'down' else 'degraded', 'app': {'status': 'up' if app == '200' else 'down', 'code': app}, 'mcp': {'status': 'up' if mcp not in ('000', 'DOWN', 'DOWN000') else 'down', 'code': mcp}, 'terminal': {'status': terminal}, 'cdp': {'status': 'up' if cdp != 'down' else 'down', 'browser': None if cdp == 'down' else cdp}}, separators=(',', ':')))"

# Run command inside container
exec +CMD:
    docker compose -f docker-compose.yml exec chainglass-dev {{CMD}}

# Stream server logs
logs:
    docker compose -f docker-compose.yml logs -f chainglass-dev

# Rebuild node_modules inside container (after dependency changes)
rebuild:
    docker compose -f docker-compose.yml exec chainglass-dev pnpm install --frozen-lockfile

# Type-check the standalone harness package
typecheck:
    pnpm exec tsc --noEmit

# Run Playwright tests against the running container
playwright *ARGS:
    npx playwright test --config=playwright.config.ts {{ARGS}}
