# Harness Development Commands

# Default - show help
default:
    @just --list

# Compute port allocation for this worktree (used by other recipes)
_ports:
    @pnpm exec tsx src/cli/index.ts ports 2>/dev/null | python3 -c "import sys,json; p=json.loads(sys.stdin.read())['data']; print(f\"HARNESS_APP_PORT={p['app']}\nHARNESS_TERMINAL_PORT={p['terminal']}\nHARNESS_CDP_PORT={p['cdp']}\nHARNESS_WORKTREE={p['worktree']}\")"

# Show port allocation for this worktree
ports:
    @pnpm exec tsx src/cli/index.ts ports

# Build Docker image
build:
    docker compose -f docker-compose.yml build

# Install standalone harness dependencies
install:
    pnpm install --ignore-workspace

# Start dev container (detached), wait for health using dynamic ports
dev:
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just _ports)"
    export HARNESS_APP_PORT HARNESS_TERMINAL_PORT HARNESS_CDP_PORT HARNESS_WORKTREE
    echo "Starting harness for worktree: $HARNESS_WORKTREE"
    echo "  App: :$HARNESS_APP_PORT  Terminal: :$HARNESS_TERMINAL_PORT  CDP: :$HARNESS_CDP_PORT"
    docker compose -f docker-compose.yml up -d
    echo "Waiting for health..."
    for i in $(seq 1 60); do
        if curl -sf "http://localhost:$HARNESS_APP_PORT" > /dev/null 2>&1; then
            echo "✓ App healthy on :$HARNESS_APP_PORT"
            break
        fi
        sleep 2
    done

# Stop and remove container
stop:
    docker compose -f docker-compose.yml down

# Health check using dynamic ports
health:
    @pnpm exec tsx src/cli/index.ts health 2>/dev/null

# Run command inside container
exec +CMD:
    docker compose -f docker-compose.yml exec chainglass-dev {{CMD}}

# Stream server logs
logs:
    docker compose -f docker-compose.yml logs -f chainglass-dev

# Rebuild node_modules inside container (after dependency changes)
rebuild:
    docker compose -f docker-compose.yml exec chainglass-dev pnpm install --frozen-lockfile

# Type-check the standalone harness package
typecheck:
    pnpm exec tsc --noEmit

# Run Playwright tests against the running container
playwright *ARGS:
    npx playwright test --config=playwright.config.ts {{ARGS}}

# Run a cg CLI command inside the harness container (auto-adds --json + --workspace-path)
# Usage: just cg wf show test-workflow --detailed
# Auto-injects --server-url for commands that need server access:
#   --server flag present, OR stop/restart subcommands (always server-mode)
cg *ARGS:
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just _ports)"
    CONTAINER="chainglass-${HARNESS_WORKTREE}"
    EXTRA_FLAGS=""
    # Auto-inject --server-url when --server is present OR for stop/restart commands
    if echo "{{ARGS}}" | grep -qE -- '--server|wf stop|wf restart'; then
      EXTRA_FLAGS="--server-url http://localhost:${HARNESS_APP_PORT}"
    fi
    docker exec "$CONTAINER" node /app/apps/cli/dist/cli.cjs \
      {{ARGS}} \
      --workspace-path /app/scratch/harness-test-workspace \
      --json \
      $EXTRA_FLAGS
