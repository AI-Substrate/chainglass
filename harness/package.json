{
  "name": "@chainglass/harness",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic development harness — Docker + Playwright browser automation for Chainglass",
  "type": "module",
  "bin": {
    "harness": "./bin/harness"
  },
  "scripts": {
    "harness": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^13.1.0",
    "zod": "^3.25.67",
    "@chainglass/shared": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
